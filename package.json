{
  "name": "attendly-production",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/index.js",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "setup": "npm install && npm run db:generate && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "latest",
    "bcryptjs": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "helmet": "latest",
    "jsonwebtoken": "latest",
    "morgan": "latest",
    "pg": "latest",
    "react": "latest",
    "react-dom": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "prisma": "latest",
    "vite": "latest"
  },
  "prisma": { "seed": "node prisma/seed.js" }
}
