generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum Role {
  ADMIN
  MANAGER
  TECHNICIAN
  OFFICE
  EMPLOYEE
}

enum PunchType {
  CLOCK_IN
  CLOCK_OUT
}

enum RequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id              String           @id @default(cuid())
  name            String
  role            Role             @default(EMPLOYEE)
  pinHash         String
  pinLast4        String
  status          EmployeeStatus   @default(ACTIVE)
  payType         String           @default("Hourly")
  hourlyRate      Decimal?         @db.Decimal(10, 2)
  vacationHours   Decimal          @default(0) @db.Decimal(10, 2)
  sickHours       Decimal          @default(0) @db.Decimal(10, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  punches         Punch[]
  timeOffRequests TimeOffRequest[]
}

model Punch {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       PunchType
  occurredAt DateTime  @default(now())
  note       String?
  createdAt  DateTime  @default(now())

  @@index([employeeId, occurredAt])
}

model TimeOffRequest {
  id          String        @id @default(cuid())
  employeeId  String
  employee    Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  hours       Decimal       @db.Decimal(10, 2)
  type        String
  reason      String?
  status      RequestStatus @default(PENDING)
  managerNote String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
}
